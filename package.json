{
  "name": "last-testament",
  "version": "1.0.0",
  "description": "last testament site",
  "main": "index.js",
  "scripts": {
    "setup": "npm run install:all && cp server/.env.example server/.env && echo 'Done! Fill in your API key in server/.env'",
    "install:all": "npm install && cd angular && npm install && cd ../server && npm install",
    "start": "concurrently \"npm run server\" \"npm run ng\"",
    "server": "cd server-exp && node server.js",
    "ng": "cd last-test-ng && ng serve",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akchdhry/last-testament.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/akchdhry/last-testament/issues"
  },
  "homepage": "https://github.com/akchdhry/last-testament#readme",
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
